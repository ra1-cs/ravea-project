@startuml
title Use Case Diagram - RAVÉA

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Guest User" as Guest
actor "Registered User" as User

rectangle "RAVÉA E-Commerce Beauty Website" {

  usecase "Browse Products" as UC_Browse
  usecase "Search / Filter Products" as UC_SearchFilter
  usecase "View Product Details" as UC_Details
  usecase "View Recommendations" as UC_Recommendations

  usecase "Register" as UC_Register
  usecase "Login" as UC_Login
  usecase "Reset Password" as UC_ResetPassword

  usecase "Manage Profile" as UC_Profile
  usecase "Add to Cart" as UC_AddCart
  usecase "Manage Cart" as UC_Cart
  usecase "Place Order" as UC_Order
  usecase "Rate Product" as UC_Rate
  usecase "Logout" as UC_Logout
}

Guest --> UC_Browse
Guest --> UC_SearchFilter
Guest --> UC_Details
Guest --> UC_Recommendations
Guest --> UC_Register
Guest --> UC_Login
Guest --> UC_ResetPassword

User --> UC_Browse
User --> UC_SearchFilter
User --> UC_Details
User --> UC_Recommendations
User --> UC_Profile
User --> UC_AddCart
User --> UC_Cart
User --> UC_Order
User --> UC_Rate
User --> UC_Logout

UC_Register --> UC_Login : <<include>>
UC_Order --> UC_Cart : <<include>>
UC_Profile --> UC_Recommendations : <<extend>>

@enduml
