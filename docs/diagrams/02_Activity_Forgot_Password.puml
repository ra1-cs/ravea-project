@startuml
title Activity Diagram - Forgot Password

start

:User enters email address;
:Frontend sends POST /api/auth/forgot-password;

:AuthController receives ForgotPasswordDto;

if (Email is empty?) then (Yes)
  :Return BadRequest;
  stop
else (No)
  :Search user by email in database;
endif

if (User exists?) then (No)
  :Return NotFound;
  stop
else (Yes)
  :Generate 6-digit reset code;
  :Set ResetCode;
  :Set ResetCodeExpiresAt = Now + 10 minutes;
  :Save changes in database;
  :Call EmailService.SendPasswordResetCodeAsync;
  :Return success message;
endif

stop
@enduml
